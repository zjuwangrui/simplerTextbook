# Copy this file to `.env` and adjust if Docker Hub is unreachable in your environment.

# Optional: override base images with a trusted internal or regional mirror.
PYTHON_BASE_IMAGE=python:3.12-slim
NODE_BASE_IMAGE=node:20-alpine
NGINX_BASE_IMAGE=nginx:1.27-alpine

# Optional: package registry overrides used during docker build.
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=
NPM_REGISTRY=
